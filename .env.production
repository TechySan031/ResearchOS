# ==============================
# ResearchOS — Production Environment
# ==============================
# IMPORTANT: Never commit this file with real secrets.
# Copy to .env.production and fill in actual values before deploying.

# ----- Application -----
APP_NAME=ResearchOS
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ----- Database (PostgreSQL via asyncpg) -----
# Container hostname "postgres" matches the compose service name
POSTGRES_DB=researchos
POSTGRES_USER=researchos
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://researchos:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/researchos

# ----- Redis -----
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_PORT=6379
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0

# ----- LLM Providers -----
MISTRAL_API_KEY=CHANGE_ME_MISTRAL_API_KEY
MISTRAL_MODEL=mistral-large-latest

KIMI_API_KEY=CHANGE_ME_KIMI_API_KEY
KIMI_MODEL=moonshot-v1-128k
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ----- Pinecone -----
PINECONE_API_KEY=CHANGE_ME_PINECONE_API_KEY
PINECONE_INDEX_NAME=research-os
PINECONE_ENVIRONMENT=us-east-1

# ----- Embeddings -----
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu

# ----- External Research APIs -----
SEMANTIC_SCHOLAR_API_KEY=CHANGE_ME_SEMANTIC_SCHOLAR_API_KEY

# ----- Rate Limiting -----
RATE_LIMIT_PER_MINUTE=60

# ----- CORS -----
# Set to your production frontend domain(s)
CORS_ORIGINS=["https://your-domain.com"]

# ----- JWT Auth -----
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# ----- Gunicorn Tuning (optional overrides) -----
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=120
# GUNICORN_LOG_LEVEL=info
