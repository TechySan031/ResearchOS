# ==============================
# ResearchOS Environment Variables
# Copy this to .env and fill in your values
# ==============================

# ----- Application -----
APP_NAME=ResearchOS
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=DEBUG

# ----- Database -----
# SQLite for development (default)
DATABASE_URL=sqlite+aiosqlite:///./researchos.db
# PostgreSQL for production
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/researchos

# ----- Redis -----
REDIS_URL=redis://localhost:6379/0

# ----- LLM Providers -----
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-large-latest

KIMI_API_KEY=your-kimi-api-key
KIMI_MODEL=moonshot-v1-128k
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ----- Pinecone -----
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=research-os
PINECONE_ENVIRONMENT=us-east-1

# ----- Embeddings -----
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu

# ----- External Research APIs -----
SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-api-key
# arXiv and CrossRef don't require API keys

# ----- Rate Limiting -----
RATE_LIMIT_PER_MINUTE=60

# ----- CORS -----
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ----- JWT Auth (Phase 6) -----
# JWT_SECRET_KEY=your-super-secret-key
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_MINUTES=30

# ----- Frontend -----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
